{
  "compilerOptions": {

    "target": "ES2016",

    "module": "commonjs",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "types": ["node"],

    "removeComments": true,

    "noImplicitAny": true,

    "noUnusedLocals": true,

    "noUnusedParameters": true,

    "noImplicitReturns": true
  }
}